# Nestorage configuration — copy to .env for local development (.env is
# gitignored). Real environment variables always override values in .env;
# .env is only read when APP_ENV is dev (or unset, since dev is the
# default). Every variable below is read by internal/platform/config, via
# nestcore's config package.

# Deployment environment: dev | test | prod
APP_ENV=dev

# HTTP listen port (a leading colon is tolerated, e.g. ":8080").
PORT=8080

# Postgres connection string. Unset in dev falls back to compose.yaml's
# local service (127.0.0.1:5433); test and prod must set this explicitly.
# DATABASE_URL=postgres://nestorage:nestorage@localhost:5433/nestorage?sslmode=disable

# --- Database pool tuning (optional) -----------------------------------------
# DB_MAX_CONNS=10
# DB_CONNECT_TIMEOUT=5s

# Bounds how long a single request may take end to end (connection-level
# ReadTimeout/WriteTimeout, and — minus a small margin — the per-request
# context deadline every handler runs under). Minimum 15s.
# SERVER_REQUEST_TIMEOUT=2m

# Optional app-terminated TLS. Set BOTH to have the server listen with TLS
# itself (ListenAndServeTLS); leave both unset to serve plain HTTP behind a
# reverse proxy (the default — see "Deployment" in CLAUDE.md for the
# tailscale serve shape this appliance runs behind).
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# --- Reverse-proxy / HTTPS (optional) ----------------------------------------
# When running behind a TLS-terminating reverse proxy (tailscale serve),
# Nestorage stays HTTP and derives the scheme from X-Forwarded-Proto, trusted
# only from TRUSTED_PROXIES.
#
# CIDRs whose X-Forwarded-* headers are trusted. Defaults to loopback (a
# same-host proxy); widen only if the proxy connects from another address.
# Empty trusts none.
# TRUSTED_PROXIES=127.0.0.0/8,::1/128
# Strict-Transport-Security (only sent over HTTPS). Enable on a stable
# HTTPS host.
# HSTS_ENABLED=true
# HSTS_MAX_AGE=4320h   # 180 days (Go duration; d/days is not valid)
# HSTS_INCLUDE_SUBDOMAINS=false
# HSTS_PRELOAD=false
# -----------------------------------------------------------------------------
